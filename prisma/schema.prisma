generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model JobPosting {
  id             String                @id @default(cuid())
  url            String                @unique
  title          String?
  company        String?
  location       String?
  platform       String?
  rawText        String
  parsedJson     String?
  normalizedJson String?
  parseVersion   String?
  decisions      ApplicationDecision[]
  preparedAnswerSets PreparedAnswerSet[]
  reviewHistory  JobReviewHistory[]
  systemLogs     SystemLog[]
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt
}

enum ApplicationDecisionType {
  APPLY
  MAYBE
  SKIP
}

model ApplicationDecision {
  id            String                  @id @default(cuid())
  jobPostingId  String
  jobPosting    JobPosting              @relation(fields: [jobPostingId], references: [id], onDelete: Cascade)
  score         Int
  decision      ApplicationDecisionType
  policyAllowed Boolean
  reasons       String
  createdAt     DateTime                @default(now())
}

model CandidateProfileSnapshot {
  id          String   @id @default(cuid())
  fullName    String?
  linkedinUrl String?
  resumePath  String?
  profileJson String
  createdAt   DateTime @default(now())
  preparedAnswerSets PreparedAnswerSet[]
}

model PreparedAnswerSet {
  id                 String   @id @default(cuid())
  jobPostingId       String?
  candidateProfileId String
  questionsJson      String
  answersJson        String
  createdAt          DateTime @default(now())
  jobPosting         JobPosting? @relation(fields: [jobPostingId], references: [id], onDelete: SetNull)
  candidateProfile   CandidateProfileSnapshot @relation(fields: [candidateProfileId], references: [id], onDelete: Cascade)
}

model AnswerCacheEntry {
  id                 String   @id @default(cuid())
  normalizedQuestion String   @unique
  label              String
  questionType       String
  strategy           String
  answerJson         String
  confidenceLabel    String
  source             String
  notesJson          String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@index([questionType, updatedAt])
}

enum SystemLogLevel {
  INFO
  WARN
  ERROR
}

model SystemLog {
  id           String         @id @default(cuid())
  level        SystemLogLevel
  scope        String
  message      String
  detailsJson  String?
  runType      String?
  jobPostingId String?
  jobUrl       String?
  jobPosting   JobPosting?    @relation(fields: [jobPostingId], references: [id], onDelete: SetNull)
  createdAt    DateTime       @default(now())

  @@index([createdAt])
  @@index([level, createdAt])
  @@index([jobUrl, createdAt])
}

enum JobReviewStatus {
  VIEWED
  EVALUATED
  SKIPPED
  READY_TO_SUBMIT
  SUBMITTED
  FAILED
}

model JobReviewHistory {
  id            String                  @id @default(cuid())
  jobPostingId  String?
  jobUrl        String
  platform      String?
  source        String
  status        JobReviewStatus
  score         Int?
  threshold     Int?
  decision      ApplicationDecisionType?
  policyAllowed Boolean?
  reasons       String
  summary       String?
  detailsJson   String?
  createdAt     DateTime                @default(now())
  jobPosting    JobPosting?             @relation(fields: [jobPostingId], references: [id], onDelete: SetNull)

  @@index([jobUrl, createdAt])
  @@index([status, createdAt])
  @@index([source, createdAt])
}
